# File: .gitignore
# Purpose: Files and directories to exclude from version control.

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/
*.pyo
*.pyd

# Virtual envs
.venv/
venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.coveragerc

# Secrets
.env
*.pem
*.key

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
*.log

# OS
.DS_Store
Thumbs.db
